# Backend-Konfiguration (Kopie als .env anlegen; .env NIE committen)

# Port und Host des HTTP-Servers
PORT=3001
HOST=0.0.0.0

# Pfad zur SQLite-Datei (wird bei Bedarf angelegt). In Docker auf ein Volume legen.
DB_PATH=./data/lernapp.sqlite

# Name des Sitzungs-Cookies
SESSION_COOKIE_NAME=ap_session

# Erlaubter Frontend-Origin für CORS (nur nötig, wenn Frontend auf anderer
# Origin läuft, z. B. im Dev: http://localhost:5173). In Produktion meist leer,
# da Frontend und API über denselben Reverse-Proxy/Origin laufen.
CORS_ORIGIN=

# In Produktion auf "production" setzen -> Secure-Flag für Cookies (nur HTTPS)
NODE_ENV=development
