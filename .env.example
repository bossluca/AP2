# Konfiguration für docker compose (Kopie als .env anlegen; .env NICHT committen).

# Port, auf dem der Frontend-Container (Nginx) auf dem LXC-Host lauscht.
# NPM zeigt auf http://<LXC-IP>:<WEB_PORT>
# Standard: 8080 (ändere ihn, falls der Port bereits belegt ist).
WEB_PORT=8080

# Name des Sitzungs-Cookies (muss nicht geändert werden).
SESSION_COOKIE_NAME=ap_session
