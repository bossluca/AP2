# Konfiguration für docker compose (Kopie als .env anlegen; .env NICHT committen).

# Adresse, unter der Caddy die App ausliefert:
#  - Lokal/Test:        :80                 (HTTP, kein Zertifikat)
#  - Produktion:        lernapp.example.de  (Caddy holt automatisch HTTPS-Zertifikat)
SITE_ADDRESS=:80

# Name des Sitzungs-Cookies (muss nicht geändert werden).
SESSION_COOKIE_NAME=ap_session
